#!/usr/bin/env python3
import gi, os, sys, signal, subprocess
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, GLib, GtkLayerShell

PIDFILE = '/tmp/wifi-popup.pid'

def toggle_or_exit():
    if os.path.exists(PIDFILE):
        try:
            pid = int(open(PIDFILE).read())
            os.kill(pid, signal.SIGTERM)
            os.unlink(PIDFILE)
            sys.exit(0)
        except (ProcessLookupError, ValueError, OSError):
            pass
    with open(PIDFILE, 'w') as f:
        f.write(str(os.getpid()))

toggle_or_exit()

# Close any other popup
for _pf in ['/tmp/volume-popup.pid']:
    try:
        os.kill(int(open(_pf).read()), signal.SIGTERM)
        os.unlink(_pf)
    except Exception:
        pass

CSS = b"""
window {
    background-color: #0a0a0a;
    border: 1px solid #27272a;
}
row {
    padding: 0;
    border-radius: 0;
    background-color: transparent;
    outline: none;
}
row:selected { background-color: #111111; outline: none; }
row:selected #net-row { color: #3f3f46; }
row:selected #net-row.connected { color: #52525b; }
#net-row {
    padding: 5px 10px;
    font-family: "JetBrains Mono";
    font-size: 11px;
    color: #a1a1aa;
}
#net-row.connected { color: #e4e4e7; }
#signal {
    font-family: "JetBrains Mono";
    font-size: 10px;
    color: #3f3f46;
    margin-left: 8px;
}
entry {
    background-color: transparent;
    color: #e4e4e7;
    border: none;
    border-radius: 0;
    border-bottom: 1px solid #52525b;
    font-family: "JetBrains Mono";
    font-size: 11px;
    padding: 0;
    box-shadow: none;
    outline: none;
    min-height: 0;
    caret-color: #e4e4e7;
}
"""

def get_networks():
    try:
        out = subprocess.check_output(
            ['nmcli', '-t', '-f', 'ACTIVE,SSID,SIGNAL,SECURITY', 'dev', 'wifi', 'list'],
            text=True)
    except Exception:
        return []
    saved = set()
    try:
        s = subprocess.check_output(['nmcli', '-t', '-f', 'NAME', 'con', 'show'], text=True)
        saved = {l.strip() for l in s.splitlines() if l.strip()}
    except Exception:
        pass
    seen, nets = set(), []
    for line in out.splitlines():
        parts = line.split(':', 3)
        if len(parts) < 4:
            continue
        active, ssid, sig, security = parts
        ssid = ssid.strip()
        if not ssid or ssid in seen:
            continue
        seen.add(ssid)
        nets.append({
            'ssid':      ssid,
            'signal':    int(sig) if sig.isdigit() else 0,
            'secured':   bool(security.strip()),
            'saved':     ssid in saved,
            'connected': active.strip() in ('sim', 'yes'),
        })
    nets.sort(key=lambda n: (not n['connected'], not n['saved'], -n['signal']))
    return nets

def connect_net(ssid, password=None):
    if password:
        subprocess.Popen(['nmcli', 'dev', 'wifi', 'connect', ssid, 'password', password])
    else:
        subprocess.Popen(['nmcli', 'con', 'up', ssid])

class WifiPopup(Gtk.Window):
    def __init__(self):
        super().__init__()

        GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGTERM, self._quit)

        GtkLayerShell.init_for_window(self)
        GtkLayerShell.set_layer(self, GtkLayerShell.Layer.TOP)
        GtkLayerShell.set_keyboard_mode(self, GtkLayerShell.KeyboardMode.ON_DEMAND)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.TOP, True)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.RIGHT, True)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.TOP, 4)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.RIGHT, 115)

        css = Gtk.CssProvider()
        css.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.set_size_request(260, -1)
        self._networks  = get_networks()
        self._active_row = None

        self.scroll = Gtk.ScrolledWindow()
        self.scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        self.scroll.set_min_content_height(min(len(self._networks) * 28, 220))
        self.scroll.set_max_content_height(220)

        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.listbox.set_activate_on_single_click(True)
        self.listbox.connect('row-activated', self._on_activate)

        for net in self._networks:
            self.listbox.add(self._make_row(net))

        self.scroll.add(self.listbox)
        self.add(self.scroll)

        self.connect('key-press-event', self._on_key)
        self.connect('destroy', self._cleanup)
        GLib.timeout_add(400, self._arm_focus_out)

        if self._networks:
            self.listbox.select_row(self.listbox.get_row_at_index(0))

    def _make_row(self, net):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        box.set_name('net-row')
        if net['connected']:
            box.get_style_context().add_class('connected')

        lbl = Gtk.Label(label=net['ssid'])
        lbl.set_halign(Gtk.Align.START)
        lbl.set_hexpand(True)
        lbl.set_ellipsize(3)

        entry = Gtk.Entry()
        entry.set_visibility(False)
        entry.set_placeholder_text('password')
        entry.set_hexpand(True)
        entry.set_no_show_all(True)
        entry.connect('activate', lambda e, s=net['ssid']: self._pwd_confirm(s, e))
        entry.connect('key-press-event', self._entry_key)

        sig  = Gtk.Label(label=f"{net['signal']}%")
        sig.set_name('signal')
        lock = Gtk.Label(label=' *' if net['secured'] else '')
        lock.set_name('signal')

        box.pack_start(lbl,   True,  True,  0)
        box.pack_start(entry, True,  True,  0)
        box.pack_start(sig,   False, False, 0)
        box.pack_start(lock,  False, False, 0)

        row = Gtk.ListBoxRow()
        row.add(box)
        row._net   = net
        row._lbl   = lbl
        row._entry = entry
        return row

    def _on_activate(self, _lb, row):
        net = row._net
        self._restore_active()
        if net['connected']:
            self._quit()
            return
        if net['secured'] and not net['saved']:
            self._active_row = row
            row._lbl.hide()
            row._entry.set_text('')
            row._entry.show()
            row._entry.grab_focus()
        else:
            connect_net(net['ssid'])
            self._quit()

    def _restore_active(self):
        if self._active_row:
            self._active_row._entry.hide()
            self._active_row._lbl.show()
            self._active_row = None

    def _pwd_confirm(self, ssid, entry):
        pwd = entry.get_text().strip()
        if pwd:
            connect_net(ssid, pwd)
        self._quit()

    def _entry_key(self, _entry, event):
        if event.keyval == Gdk.KEY_Escape:
            self._restore_active()
            self.listbox.grab_focus()
        return False

    def _scroll_to(self, row):
        alloc = row.get_allocation()
        adj   = self.scroll.get_vadjustment()
        val   = adj.get_value()
        page  = adj.get_page_size()
        if alloc.y < val:
            adj.set_value(alloc.y)
        elif alloc.y + alloc.height > val + page:
            adj.set_value(alloc.y + alloc.height - page)

    def _move(self, delta):
        self._restore_active()
        row = self.listbox.get_selected_row()
        idx = row.get_index() if row else -1
        nxt = self.listbox.get_row_at_index(idx + delta)
        if nxt:
            self.listbox.select_row(nxt)
            self._scroll_to(nxt)

    def _on_key(self, _w, event):
        if self._active_row:
            return False
        k = event.keyval
        if k in (Gdk.KEY_Escape, ord('q')):
            self._quit()
        elif k in (ord('j'), Gdk.KEY_Down):
            self._move(+1)
        elif k in (ord('k'), Gdk.KEY_Up):
            self._move(-1)
        elif k in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            row = self.listbox.get_selected_row()
            if row:
                self._on_activate(self.listbox, row)
        elif k == ord('r'):
            subprocess.Popen(['nmcli', 'dev', 'wifi', 'rescan'])
            GLib.timeout_add(2000, self._reload)
        return True

    def _reload(self):
        self._networks = get_networks()
        for child in self.listbox.get_children():
            self.listbox.remove(child)
        for net in self._networks:
            self.listbox.add(self._make_row(net))
        self.listbox.show_all()
        if self._networks:
            self.listbox.select_row(self.listbox.get_row_at_index(0))
        return False

    def _arm_focus_out(self):
        self.connect('focus-out-event', lambda *_: GLib.timeout_add(100, self._quit))
        return False

    def _cleanup(self, *_):
        try:
            os.unlink(PIDFILE)
        except OSError:
            pass

    def _quit(self, *_):
        self._cleanup()
        Gtk.main_quit()
        return False

win = WifiPopup()
win.show_all()
Gtk.main()
