#!/usr/bin/env python3
import gi, os, sys, signal, subprocess
gi.require_version('Gtk', '3.0')
gi.require_version('GtkLayerShell', '0.1')
from gi.repository import Gtk, Gdk, GLib, GtkLayerShell

PIDFILE = '/tmp/wifi-popup.pid'

def toggle_or_exit():
    if os.path.exists(PIDFILE):
        try:
            pid = int(open(PIDFILE).read())
            os.kill(pid, signal.SIGTERM)
            os.unlink(PIDFILE)
            sys.exit(0)
        except (ProcessLookupError, ValueError, OSError):
            pass
    with open(PIDFILE, 'w') as f:
        f.write(str(os.getpid()))

toggle_or_exit()

CSS = b"""
window {
    background-color: #0a0a0a;
    border: 1px solid #27272a;
}
row {
    padding: 0;
    border-radius: 0;
    background-color: transparent;
    outline: none;
}
row:selected, row:focus {
    background-color: #111111;
    outline: none;
}
#net-row {
    padding: 5px 10px;
    font-family: "JetBrains Mono";
    font-size: 11px;
    color: #71717a;
}
#net-row.connected {
    color: #e4e4e7;
}
#net-row.saved {
    color: #a1a1aa;
}
#signal {
    font-family: "JetBrains Mono";
    font-size: 10px;
    color: #3f3f46;
    margin-left: 8px;
}
#pwd-view {
    padding: 10px;
}
#pwd-ssid {
    color: #71717a;
    font-family: "JetBrains Mono";
    font-size: 11px;
    margin-bottom: 6px;
}
entry {
    background-color: #111111;
    color: #e4e4e7;
    border: 1px solid #27272a;
    border-radius: 0;
    font-family: "JetBrains Mono";
    font-size: 11px;
    padding: 4px 8px;
    box-shadow: none;
    outline: none;
    caret-color: #e4e4e7;
}
entry:focus {
    border-color: #52525b;
}
"""

def get_networks():
    try:
        out = subprocess.check_output(
            ['nmcli', '-t', '-f', 'ACTIVE,SSID,SIGNAL,SECURITY', 'dev', 'wifi', 'list'],
            text=True)
    except Exception:
        return []

    saved = set()
    try:
        s = subprocess.check_output(['nmcli', '-t', '-f', 'NAME', 'con', 'show'], text=True)
        saved = {l.strip() for l in s.splitlines() if l.strip()}
    except Exception:
        pass

    seen, nets = set(), []
    for line in out.splitlines():
        parts = line.split(':', 3)
        if len(parts) < 4:
            continue
        active, ssid, sig, security = parts
        ssid = ssid.strip()
        if not ssid or ssid in seen:
            continue
        seen.add(ssid)
        nets.append({
            'ssid':      ssid,
            'signal':    int(sig) if sig.isdigit() else 0,
            'secured':   bool(security.strip()),
            'saved':     ssid in saved,
            'connected': active.strip() in ('sim', 'yes'),
        })

    nets.sort(key=lambda n: (not n['connected'], not n['saved'], -n['signal']))
    return nets

def connect(ssid, password=None):
    if password:
        subprocess.Popen(['nmcli', 'dev', 'wifi', 'connect', ssid, 'password', password])
    else:
        subprocess.Popen(['nmcli', 'con', 'up', ssid])

class WifiPopup(Gtk.Window):
    def __init__(self):
        super().__init__()

        # SIGTERM handler so waybar toggle works
        GLib.unix_signal_add(GLib.PRIORITY_DEFAULT, signal.SIGTERM, self._quit)

        GtkLayerShell.init_for_window(self)
        GtkLayerShell.set_layer(self, GtkLayerShell.Layer.TOP)
        GtkLayerShell.set_keyboard_mode(self, GtkLayerShell.KeyboardMode.ON_DEMAND)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.TOP, True)
        GtkLayerShell.set_anchor(self, GtkLayerShell.Edge.RIGHT, True)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.TOP, 4)
        GtkLayerShell.set_margin(self, GtkLayerShell.Edge.RIGHT, 150)

        css = Gtk.CssProvider()
        css.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self.set_size_request(260, -1)
        self._networks = get_networks()

        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.NONE)

        # ── List view ──
        self.list_box_outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        scroll.set_min_content_height(min(len(self._networks) * 28, 220))
        scroll.set_max_content_height(220)

        self.listbox = Gtk.ListBox()
        self.listbox.set_selection_mode(Gtk.SelectionMode.SINGLE)
        self.listbox.set_activate_on_single_click(True)
        self.listbox.connect('row-activated', self._on_activate)

        for net in self._networks:
            self.listbox.add(self._make_row(net))

        scroll.add(self.listbox)
        self.list_box_outer.pack_start(scroll, False, False, 0)
        self.stack.add_named(self.list_box_outer, 'list')

        # ── Password view ──
        self.pwd_view = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        self.pwd_view.set_name('pwd-view')

        self.pwd_entry = Gtk.Entry()
        self.pwd_entry.set_visibility(False)
        self.pwd_entry.set_placeholder_text('password')
        self.pwd_entry.connect('activate', self._on_pwd_enter)

        self.pwd_view.pack_start(self.pwd_entry, False, False, 0)
        self.stack.add_named(self.pwd_view, 'password')

        self.add(self.stack)
        self.connect('key-press-event', self._on_key)
        self.connect('destroy', self._cleanup)

        if self._networks:
            self.listbox.select_row(self.listbox.get_row_at_index(0))

    def _make_row(self, net):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        box.set_name('net-row')
        ctx = box.get_style_context()
        if net['connected']:
            ctx.add_class('connected')
        elif net['saved']:
            ctx.add_class('saved')

        lbl = Gtk.Label(label=net['ssid'])
        lbl.set_halign(Gtk.Align.START)
        lbl.set_hexpand(True)
        lbl.set_ellipsize(3)

        sig = Gtk.Label(label=f"{net['signal']}%")
        sig.set_name('signal')

        lock = Gtk.Label(label=' *' if net['secured'] else '')
        lock.set_name('signal')

        box.pack_start(lbl, True, True, 0)
        box.pack_start(sig, False, False, 0)
        box.pack_start(lock, False, False, 0)

        row = Gtk.ListBoxRow()
        row.add(box)
        row._net = net
        return row

    def _on_activate(self, _lb, row):
        net = row._net
        if net['connected']:
            self._quit()
            return
        if net['secured'] and not net['saved']:
            self._pending = net['ssid']
            self.pwd_entry.set_text('')
            self.stack.set_visible_child_name('password')
            self.pwd_entry.grab_focus()
        else:
            connect(net['ssid'])
            self._quit()

    def _on_pwd_enter(self, entry):
        pwd = entry.get_text().strip()
        if pwd:
            connect(self._pending, pwd)
        self._quit()

    def _on_key(self, _w, event):
        k = event.keyval
        current = self.stack.get_visible_child_name()

        if current == 'password':
            if k == Gdk.KEY_Escape:
                self.stack.set_visible_child_name('list')
            return False  # let entry handle typing

        if k in (Gdk.KEY_Escape, ord('q')):
            self._quit()
        elif k in (ord('j'), Gdk.KEY_Down):
            row = self.listbox.get_selected_row()
            if row:
                nxt = self.listbox.get_row_at_index(row.get_index() + 1)
                if nxt:
                    self.listbox.select_row(nxt)
        elif k in (ord('k'), Gdk.KEY_Up):
            row = self.listbox.get_selected_row()
            if row:
                prv = self.listbox.get_row_at_index(row.get_index() - 1)
                if prv:
                    self.listbox.select_row(prv)
        elif k in (Gdk.KEY_Return, Gdk.KEY_KP_Enter):
            row = self.listbox.get_selected_row()
            if row:
                self._on_activate(self.listbox, row)
        elif k == ord('r'):
            subprocess.Popen(['nmcli', 'dev', 'wifi', 'rescan'])
            GLib.timeout_add(2000, self._reload)
        return True

    def _reload(self):
        self._networks = get_networks()
        for child in self.listbox.get_children():
            self.listbox.remove(child)
        for net in self._networks:
            self.listbox.add(self._make_row(net))
        self.listbox.show_all()
        if self._networks:
            self.listbox.select_row(self.listbox.get_row_at_index(0))
        return False

    def _cleanup(self, *_):
        try:
            os.unlink(PIDFILE)
        except OSError:
            pass

    def _quit(self, *_):
        self._cleanup()
        Gtk.main_quit()
        return False

win = WifiPopup()
win.show_all()
Gtk.main()
