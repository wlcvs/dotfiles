#!/usr/bin/env python3
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk, Gdk, GLib
import subprocess

CSS = b"""
window {
    background-color: #0a0a0a;
    border: 1px solid #27272a;
}
box {
    padding: 10px 8px;
}
scale {
    outline: none;
}
scale trough {
    background-color: #27272a;
    min-width: 6px;
    border-radius: 0;
}
scale highlight {
    background-color: #52525b;
    border-radius: 0;
}
scale slider {
    background-color: #e4e4e7;
    border-radius: 0;
    min-width: 22px;
    min-height: 8px;
    border: none;
    box-shadow: none;
    margin: -8px 0;
}
label {
    color: #71717a;
    font-family: "JetBrains Mono";
    font-size: 10px;
    margin-top: 6px;
}
"""

def get_volume():
    try:
        out = subprocess.check_output(
            ['wpctl', 'get-volume', '@DEFAULT_AUDIO_SINK@'], text=True)
        # output: "Volume: 0.60" or "Volume: 0.60 [MUTED]"
        return round(float(out.split()[1]) * 100)
    except Exception:
        return 50

def set_volume(vol):
    subprocess.run(
        ['wpctl', 'set-volume', '-l', '1.0', '@DEFAULT_AUDIO_SINK@', f'{max(0, min(100, int(vol)))}%'])

class VolumePopup(Gtk.Window):
    def __init__(self):
        super().__init__()
        self.set_title('volume-popup')
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_keep_above(True)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)

        css = Gtk.CssProvider()
        css.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            Gdk.Screen.get_default(), css,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)

        self.scale = Gtk.Scale.new_with_range(Gtk.Orientation.VERTICAL, 0, 100, 1)
        self.scale.set_inverted(True)
        self.scale.set_draw_value(False)
        self.scale.set_size_request(40, 180)
        self.scale.set_value(get_volume())
        self.scale.connect('value-changed', self.on_value_changed)

        self.label = Gtk.Label(label=f'{int(self.scale.get_value())}%')

        box.pack_start(self.scale, True, True, 0)
        box.pack_start(self.label, False, False, 0)
        self.add(box)

        self.connect('key-press-event', self.on_key_press)
        self.connect('focus-out-event', lambda *_: GLib.timeout_add(100, Gtk.main_quit))

    def on_value_changed(self, scale):
        vol = int(scale.get_value())
        self.label.set_text(f'{vol}%')
        set_volume(vol)

    def on_key_press(self, _widget, event):
        cur = self.scale.get_value()
        key = event.keyval
        if key == Gdk.KEY_Escape:
            Gtk.main_quit()
        elif key in (Gdk.KEY_Up, ord('k')):
            self.scale.set_value(min(100, cur + 5))
        elif key in (Gdk.KEY_Down, ord('j')):
            self.scale.set_value(max(0, cur - 5))
        return True

win = VolumePopup()
win.show_all()
win.present()
win.grab_focus()
Gtk.main()
